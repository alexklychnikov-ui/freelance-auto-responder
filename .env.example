# ProxyAPI / OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# Telegram (approve-bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Browser
BROWSER_ADAPTER=external
BROWSERMCP_SERVER=C:/Python/Projects/BrowserMCP/packages/mcp-server/dist/index.js
BROWSER_NAVIGATE_WAIT_SECONDS=2

# Paths
RESPONSE_JOURNAL=C:/Python/Projects/Zerocode2md/ResponseJournal/journal.xlsx
DATABASE_PATH=data/seen_projects.db
SOURCES_CONFIG_PATH=config/sources.yaml
LIGHTRAG_MCP=user-lightrag

LIGHTRAG_MCP=user-lightrag
LIGHTRAG_BASE_URL=http://127.0.0.1:9621
LIGHTRAG_API_KEY=

# Headroom — сжатие контекста (LightRAG → GPT, MCP в Cursor)
# Proxy: deploy/Start-HeadroomProxy.ps1 (Docker, порт 8787)
HEADROOM_PROXY_URL=http://127.0.0.1:8787
HEADROOM_COMPRESS_CONTEXT=true
HEADROOM_CONTEXT_MIN_CHARS=2500

# Kwork auto-login (optional; never commit real values)
KWORK_LOGIN=
KWORK_PASSWORD=
KWORK_AUTO_LOGIN=false
KWORK_STORAGE_STATE=data/kwork_storage.json

# Behavior
SCAN_INTERVAL_MINUTES=15
MIN_GPT_SCORE=7
BUDGET_CEILING_PRICE_MULTIPLIER=2.0
MAX_DAILY_RESPONSES=5
REQUIRE_TELEGRAM_APPROVAL=true
SCAN_BOOTSTRAP_SKIP_PIPELINE=true
SCAN_EARLY_EXIT_KNOWN_COUNT=5
PREPARE_ONLY_NO_SUBMIT=true
DEFAULT_OFFER_DAYS=14
PREPARED_RESPONSES_DIR=data/prepared_responses
PENDING_TIMEOUT_HOURS=24
# Required in production: directory with *.md response examples for GPT
RESPONSE_EXAMPLES_DIR=C:/Python/Projects/Zerocode2md/Output/Отклики
